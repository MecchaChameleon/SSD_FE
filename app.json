{
  "expo": {
    "name": "로컬타임",
    "slug": "localtime",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "jejulocaltime",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#ffffff",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.localtime.app"
    },
    "android": {
      "package": "com.localtime.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "name": "로컬타임"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "상품 사진을 등록하려면 사진 보관함 접근 권한이 필요합니다.",
          "cameraPermission": false
        }
      ]
    ]
  }
}
